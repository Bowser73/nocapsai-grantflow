# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/grantflow_dev"

# ─── Auth ────────────────────────────────────────────────────────────────────
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# ─── LLM Provider ────────────────────────────────────────────────────────────
# Swap this to Anthropic, Mistral, etc. by updating lib/llm/provider.ts
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o"                  # Override model here

# ─── File Storage ────────────────────────────────────────────────────────────
# Development: files are stored locally in /public/uploads
# Production: connect S3-compatible storage
# UPLOADTHING_SECRET=""
# UPLOADTHING_APP_ID=""
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
# AWS_REGION="us-east-1"
# AWS_BUCKET_NAME=""

# ─── Email / Notifications ───────────────────────────────────────────────────
# Connect Resend or SendGrid for deadline reminders
# RESEND_API_KEY=""
# EMAIL_FROM="noreply@grantflow.ai"

# ─── Grant Data Sources ──────────────────────────────────────────────────────
# Grants.gov API (free, public)
GRANTS_GOV_API_URL="https://apply07.grants.gov/grantsws/rest/opportunities/search"
# SAM.gov API key (register at sam.gov)
# SAM_GOV_API_KEY=""

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
